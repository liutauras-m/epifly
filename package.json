{
  "name": "epifly-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @epifly/web dev",
    "dev:native": "pnpm --filter @epifly/native dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "check": "pnpm -r --if-present check-types",
    "lint": "pnpm -r --if-present lint",
    "e2e": "playwright test",
    "e2e:web": "playwright test --project=web"
  },
  "devDependencies": {
    "@dokploy/sdk": "^0.29.4",
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@wdio/cli": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "appium": "^3.4.2",
    "appium-xcuitest-driver": "^11.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "knip": "^6.14.2",
    "ts-node": "^10.9.2",
    "webdriverio": "^9.27.1"
  },
  "dependencies": {},
  "knip": {
    "ignoreDependencies": [
      "@sveltejs/adapter-node"
    ]
  }
}
