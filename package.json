{
  "name": "conusai-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present test",
    "check": "pnpm --filter web lint && pnpm --filter browser-shell check-types && pnpm --filter @conusai/ui check-types && pnpm --filter @conusai/epifly check-types",
    "lint": "pnpm -r lint",
    "knip": "knip --production --dependencies",
    "gate": "pnpm check && pnpm lint && pnpm test && pnpm build && pnpm knip",
    "lint:svelte": "eslint 'packages/ui/src/**/*.svelte' 'apps/web/src/**/*.svelte' 'apps/browser-shell/src/**/*.svelte'",
    "ui:contracts": "node packages/ui/scripts/check-ui-contracts.mjs",
    "ui:motion:durations": "node packages/ui/scripts/check-motion-durations.mjs",
    "ui:motion:purpose": "node packages/ui/scripts/check-motion-purpose.mjs",
    "ui:no-local": "node packages/ui/scripts/check-no-local-components.mjs",
    "ui:tokens:build": "node packages/ui/scripts/build-tokens.mjs",
    "ui:tokens:check": "node scripts/check-design-tokens.mjs",
    "test:exports": "pnpm --filter @conusai/ui exec vitest run tests/exports.test.ts",
    "ui:gates": "pnpm ui:contracts && pnpm ui:tokens:check && pnpm ui:motion:durations && pnpm ui:motion:purpose && pnpm ui:no-local && pnpm test:exports",
    "ui:runes-status": "node scripts/dump-runes-status.mjs",
    "ui:cross-platform-diff": "node scripts/cross-platform-diff.mjs",
    "audit:phase": "node scripts/audit-phase.mjs",
    "e2e": "playwright test",
    "e2e:web": "playwright test --project=web",
    "e2e:ios": "playwright test --project=ios-mobile-web",
    "e2e:shell": "playwright test --project=shell-macos",
    "e2e:all": "playwright test",
    "appium": "appium server --port 4723 --base-path /",
    "wdio:macos": "wdio run e2e/wdio/wdio.macos.conf.ts",
    "wdio:ios": "wdio run e2e/wdio/wdio.ios.conf.ts",
    "wdio:ios-native": "wdio run e2e/wdio/wdio.ios-native.conf.ts",
    "ios:build": "pnpm --filter browser-shell exec tauri ios build --target aarch64-sim --debug",
    "ios:install": "xcrun simctl install booted 'apps/browser-shell/src-tauri/gen/apple/build/arm64-sim/ConusAI Browser.app'",
    "tauri-wd": "tauri-wd --port 4444"
  },
  "devDependencies": {
    "@dokploy/sdk": "^0.29.4",
    "@playwright/test": "^1.49.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@wdio/cli": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "appium": "^3.4.2",
    "appium-xcuitest-driver": "^11.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "knip": "^6.14.2",
    "ts-node": "^10.9.2",
    "webdriverio": "^9.27.1"
  },
  "dependencies": {},
  "knip": {
    "ignoreDependencies": [
      "@sveltejs/adapter-node"
    ]
  }
}
