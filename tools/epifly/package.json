{
  "name": "@conusai/epifly",
  "version": "0.1.0",
  "description": "Epifly operator CLI — manage Dokploy-hosted Epifly stacks",
  "type": "module",
  "bin": {
    "epifly": "dist/epifly.mjs"
  },
  "main": "dist/epifly.mjs",
  "exports": {
    ".": "./dist/epifly.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check src",
    "check-types": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPattern=tests/unit",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --testPathPattern=tests/e2e --runInBand",
    "test:all": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22"
  }
}
