# ─────────────────────────────────────────────────────────────────────────────
# Conusai — Dokploy Shared Environment
# Copy into Dokploy → Project → Settings → Shared Environment.
# DO NOT commit real values. Rotate every `changeme_*` before first deploy.
# ─────────────────────────────────────────────────────────────────────────────

# Public domain — bare = web app, services live at <svc>.${APP_DOMAIN}
#   web:        https://${APP_DOMAIN}                  (e.g. epifly.beta.test.cloud.conusai.com)
#   gateway:    https://api.${APP_DOMAIN}
#   zitadel:    https://auth.${APP_DOMAIN}
#   lago:       https://billing.${APP_DOMAIN}
#   rustfs S3:  https://s3.${APP_DOMAIN}
#   rustfs UI:  https://s3-console.${APP_DOMAIN}
#   jaeger:     https://traces.${APP_DOMAIN}
APP_DOMAIN=epifly.beta.test.cloud.conusai.com

# Cookie scope so Zitadel SSO covers web + gateway + lago in one session.
COOKIE_DOMAIN=.epifly.beta.test.cloud.conusai.com

# Traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# ── Postgres (shared by Zitadel + Lago + future apps) ───────────────────────
POSTGRES_USER=conusai
POSTGRES_PASSWORD=changeme_postgres_strong_password
POSTGRES_DB=conusai

# ── Zitadel ─────────────────────────────────────────────────────────────────
ZITADEL_MASTERKEY=changeme_zitadel_master_key_32ch
# Filled in after first Zitadel admin setup:
ZITADEL_ISSUER=https://auth.epifly.beta.test.cloud.conusai.com
ZITADEL_CLIENT_ID=

# ── Lago ────────────────────────────────────────────────────────────────────
LAGO_SECRET_KEY_BASE=changeme_lago_secret_key_base_at_least_64_chars_long_xxxxxxxxxxxxxxxxxx
LAGO_ENCRYPTION_DET_KEY=changeme_det_key_32_chars_______
LAGO_ENCRYPTION_SALT=changeme_salt_32________________
LAGO_ENCRYPTION_KEY=changeme_primary_32_chars_______
LAGO_RSA_PRIVATE_KEY=
LAGO_API_KEY=
STRIPE_SECRET_KEY=

# ── RustFS (S3-compatible object storage) ───────────────────────────────────
AWS_ACCESS_KEY_ID=changeme_rustfs_access_key
AWS_SECRET_ACCESS_KEY=changeme_rustfs_secret_key
RUSTFS_VERSIONING=on
RUSTFS_PER_TENANT_IAM=on
RUSTFS_SSE=on
RUSTFS_NOTIFICATIONS=on
RUSTFS_QUOTAS=on
RUSTFS_PRESIGN_TTL_SECS=900
RUSTFS_IAM_ENC_KEY=changeme_rustfs_iam_enc_key_32ch
RUSTFS_WEBHOOK_SECRET=changeme_rustfs_webhook_secret

# ── Agent gateway ───────────────────────────────────────────────────────────
UI_SESSION_KEY=changeme_ui_session_key_at_least_32_bytes
PLATFORM_ADMIN_TOKEN=changeme_platform_admin_token
EMBEDDING_BACKEND=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Observability ───────────────────────────────────────────────────────────
OTLP_ENDPOINT=http://conusai-otel:4317

# ── Dokploy self-API (used by the `domain-sync` init service in every stack
#    to register hosts from `dokploy/domains.yaml` on each deploy) ──────────
# Auto-filled by `generate-prod-env.mjs` from `dokploy/.dokploy` if present.
DOKPLOY_URL=
DOKPLOY_ENVIRONMENT_ID=
DOKPLOY_API_KEY=
