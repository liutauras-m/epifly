{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Epifly",
  "version": "0.1.0",
  "identifier": "app.epifly.client",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Epifly",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "host": "auth.epifly.app",
          "pathPrefix": ["/native"]
        }
      ],
      "desktop": {
        "schemes": ["epifly"]
      }
    }
  }
}
