{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile",
  "description": "Mobile-specific Epifly permissions",
  "windows": ["main"],
  "local": true,
  "remote": {
    "urls": [
      "http://localhost:1420",
      "http://localhost:1420/**",
      "http://tauri.localhost",
      "http://tauri.localhost/**"
    ]
  },
  "permissions": [
    "core:default",
    "deep-link:default",
    "opener:allow-open-url",
    "allow-auth-start",
    "allow-auth-get-access-token",
    "allow-auth-sign-out"
  ]
}
