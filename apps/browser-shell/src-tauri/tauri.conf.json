{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ConusAI Browser",
  "version": "0.4.0",
  "identifier": "com.conusai.browser",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm --filter browser-shell dev",
    "beforeBuildCommand": "pnpm --filter browser-shell build"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* http://10.0.2.2:* https: wss:; img-src 'self' http://localhost:* http://127.0.0.1:* http://10.0.2.2:* data: blob:"
    },
    "windows": [
      {
        "title": "ConusAI Browser",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "macos/entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "minimumSystemVersion": "12.0",
      "signingIdentity": null
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "signCommand": null
    },
    "iOS": {
      "developmentTeam": null,
      "minimumSystemVersion": "16.0",
      "frameworks": []
    },
    "android": {
      "minSdkVersion": 26
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "host": "open",
          "pathPrefix": ["/"]
        }
      ],
      "desktop": {
        "schemes": ["conusai"]
      }
    }
  }
}
