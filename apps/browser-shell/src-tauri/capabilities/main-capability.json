{
  "$schema": "../node_modules/@tauri-apps/cli/schema/capability.json",
  "identifier": "main-window",
  "description": "Permissions for the main browser-shell window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:event:default",
    "dialog:default",
    "http:default",
    "stronghold:default",
    "haptics:default"
  ]
}
