# ── LLM Provider ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...          # optional; required for OpenAI embedding backend

# ── Server ────────────────────────────────────────────────────────────────────
CONUSAI_SERVER__HOST=0.0.0.0
CONUSAI_SERVER__PORT=8080

# ── Storage — redb (embedded metadata store) ──────────────────────────────────
REDB_PATH=/data/conusai.redb

# ── Storage — Qdrant (vector search) ─────────────────────────────────────────
QDRANT_URL=http://localhost:6334

# ── Storage — S3-compatible object store (RustFS / MinIO) ─────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=workspace
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── Marker (PDF → Markdown) ───────────────────────────────────────────────────
# MARKER_URL=http://localhost:8081

# ── Workspace indexer ─────────────────────────────────────────────────────────
WORKSPACES_ROOT=./workspaces

# ── Embedding backend ─────────────────────────────────────────────────────────
# EMBEDDING_BACKEND=openai     # "openai" (default) or "local" (requires local-embeddings feature)

# ── Capabilities ──────────────────────────────────────────────────────────────
CONUSAI_CAPABILITIES_DIR=./capabilities

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
# Foundry UI session cookie HMAC key (must be 32+ bytes in production)
UI_SESSION_KEY=conusai-foundry-dev-secret-change-me-32b
# Optional: override the dir served at /assets (defaults to crates/agent-gateway/assets)
# CONUSAI_UI_ASSETS=/srv/ui-assets

# ── Platform admin (capability self-registration) ──────────────────────────────
# PLATFORM_ADMIN_TOKEN=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
WEB_ORIGIN=http://localhost:3000,http://localhost:5173,https://tauri.localhost,tauri://localhost

# ── Telemetry ─────────────────────────────────────────────────────────────────
CONUSAI_TELEMETRY__LOG_LEVEL=info
# CONUSAI_TELEMETRY__OTLP_ENDPOINT=http://localhost:4317

# ── Google Workspace capability ───────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback
