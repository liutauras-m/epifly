# ── LLM Provider ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...          # optional fallback

# ── Server ────────────────────────────────────────────────────────────────────
CONUSAI_SERVER__HOST=0.0.0.0
CONUSAI_SERVER__PORT=8080

# ── Qdrant ────────────────────────────────────────────────────────────────────
CONUSAI_QDRANT__URL=http://localhost:6334
CONUSAI_QDRANT__COLLECTION=capabilities

# ── Capabilities ──────────────────────────────────────────────────────────────
CONUSAI_CAPABILITIES_DIR=./capabilities

# ── S3 / MinIO (file-storage capability) ──────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=conusai

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Telemetry ─────────────────────────────────────────────────────────────────
CONUSAI_TELEMETRY__LOG_LEVEL=info
# CONUSAI_TELEMETRY__OTLP_ENDPOINT=http://localhost:4317

# ── Google Workspace capability ───────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8080/oauth/callback
