{
  "name": "@conusai/ui",
  "version": "0.6.0",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "import": "./src/lib/index.ts"
    },
    "./assets/*": "./src/lib/assets/*",
    "./tokens.css": "./src/lib/tokens.css",
    "./foundry.css": "./src/lib/foundry.css",
    "./components/*": "./src/lib/components/*",
    "./features/*": "./src/lib/features/*",
    "./utils/*": "./src/lib/utils/*",
    "./stores/*": "./src/lib/stores/*",
    "./capabilities": {
      "types": "./src/lib/capabilities/index.ts",
      "import": "./src/lib/capabilities/index.ts"
    },
    "./stores": {
      "types": "./src/lib/stores/index.ts",
      "import": "./src/lib/stores/index.ts"
    },
    "./utils": {
      "types": "./src/lib/utils/index.ts",
      "import": "./src/lib/utils/index.ts"
    },
    "./features": {
      "types": "./src/lib/features/index.ts",
      "svelte": "./src/lib/features/index.ts",
      "import": "./src/lib/features/index.ts"
    },
    "./motion": {
      "types": "./src/lib/motion/index.ts",
      "import": "./src/lib/motion/index.ts"
    },
    "./live": {
      "types": "./src/lib/live/createLiveResource.svelte.ts",
      "import": "./src/lib/live/createLiveResource.svelte.ts"
    },
    "./gallery.types": {
      "types": "./src/lib/gallery.types.ts",
      "import": "./src/lib/gallery.types.ts"
    }
  },
  "scripts": {
    "build": "pnpm tokens:build",
    "check-types": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "assets:verify": "node scripts/assets-verify.js",
    "contracts": "node scripts/check-ui-contracts.mjs",
    "motion:durations": "node scripts/check-motion-durations.mjs",
    "motion:purpose": "node scripts/check-motion-purpose.mjs",
    "no-local": "node scripts/check-no-local-components.mjs",
    "tokens:build": "node scripts/build-tokens.mjs"
  },
  "dependencies": {
    "@conusai/sdk": "workspace:*",
    "@conusai/types": "workspace:*",
    "@tauri-apps/plugin-haptics": "^2.3.2"
  },
  "devDependencies": {
    "@lucide/svelte": "^1.16.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@testing-library/svelte": "^5.0.0",
    "jsdom": "^29.1.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@conusai/sdk": "workspace:*",
    "svelte": "^5.0.0"
  }
}
